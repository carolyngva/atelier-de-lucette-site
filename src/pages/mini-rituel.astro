---
// L'Atelier de Lucette — Page d'inscription gratuite
// Lead magnet : Récit audio "Deux burn-out pour comprendre" + série email
import '../styles/global.css';

const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID || '118700902141020';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Découvre ta direction d'âme — L'Atelier de Lucette</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNKPGHZL0Y"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (window.location.search.includes('tr=internal')) {
        try { localStorage.setItem('__internal', '1'); } catch(e) {}
      }
      var __int = false;
      try { __int = localStorage.getItem('__internal') === '1'; } catch(e) {}
      gtag('config', 'G-SNKPGHZL0Y', __int ? { 'traffic_type': 'internal' } : {});
    </script>
    <style>
      :root {
        --color-cream: #F7F4EE;
        --color-bone: #FFFCF6;
        --color-sable: #C9A96E;
        --color-sable-doux: #F1D9A7;
        --color-terre: #D4845A;
        --color-terre-fonce: #1E3A8A;
        --color-eau: #2AACCB;
        --color-eau-fonce: #1E3A8A;
        --color-magenta: #CC3DAA;
        --color-texte: #1E3A8A;
        --color-texte-doux: #1f2b58;
        --color-blanc: #FFFFFF;
      }
      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background-color: var(--color-cream);
        color: var(--color-texte);
        -webkit-font-smoothing: antialiased;
      }
      button,
      a,
      .ui-text,
      [class*="uppercase"] {
        font-family: 'Special Elite', 'Courier New', monospace;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Cormorant Garamond', serif;
      }
      h1 .italic,
      h2 .italic,
      .script-accent {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
        font-size: 1em;
        line-height: 1;
        display: inline-block;
      }
      .bg-grain {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
      }
      .luxury-card {
        background: rgba(251, 247, 241, 0.4);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(45, 42, 53, 0.08);
        box-shadow: 0 20px 40px -4px rgba(45, 42, 53, 0.05);
      }
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .animate-marquee {
        animation: marquee 40s linear infinite;
      }
      .mask-linear-fade {
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
      }
      .flip-card {
        perspective: 1000px;
      }
      .flip-card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        transition: transform 0.7s ease-out;
        transform-style: preserve-3d;
      }
      @media (prefers-reduced-motion: no-preference) {
        .flip-card:hover .flip-card-inner,
        .flip-card:focus-within .flip-card-inner {
          transform: rotateY(180deg);
        }
      }
      .flip-card-front,
      .flip-card-back {
        position: absolute;
        inset: 0;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
        border-radius: 1rem;
        overflow: hidden;
      }
      .flip-card-back {
        transform: rotateY(180deg);
      }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-thumb { background: var(--color-sable-doux); border-radius: 0; }

      /* MailerLite form */
      .ml-form-embedSubmitLoad { display: inline-block; width: 20px; height: 20px; }
      .ml-form-embedSubmitLoad:after { content: " "; display: block; width: 11px; height: 11px; margin: 4px auto; border-radius: 50%; border: 3px solid #fff; border-color: #fff #fff #fff transparent; animation: ml-spin 1.2s linear infinite; }
      @keyframes ml-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
      .ml-error input { border-color: #CC3DAA !important; }
      .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
    </style>

    <script is:inline src="https://groot.mailerlite.com/js/w/webforms.min.js?v83147fa8ce2d95cb73ece7f28b469519" defer></script>

    {metaPixelId && (
      <script define:vars={{ metaPixelId }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', metaPixelId);
        fbq('track', 'PageView');
      </script>
    )}
  </head>

  <body class="selection:bg-[#CC3DAA] selection:text-[#F7F4EE] relative overflow-x-hidden text-lg">
    {metaPixelId && (
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    )}

    <!-- Geometrie de fond -->
    <div class="arch-lines">
      <svg width="100%" height="100%" viewBox="0 0 1440 900" preserveAspectRatio="none">
        <line x1="10%" y1="0" x2="10%" y2="100%" stroke="#1E3A8A" stroke-width="0.5" />
        <line x1="90%" y1="0" x2="90%" y2="100%" stroke="#1E3A8A" stroke-width="0.5" />
        <line x1="50%" y1="0" x2="50%" y2="100%" stroke="#1E3A8A" stroke-width="0.5" stroke-dasharray="4 8" />
        <line x1="0" y1="800" x2="1440" y2="400" stroke="#CC3DAA" stroke-width="0.5" opacity="0.55" />
      </svg>
    </div>

    <!-- Navigation -->
    <nav class="fixed top-0 inset-x-0 z-50 h-24 flex items-center border-b border-[#1E3A8A]/20 bg-[#F7F4EE]/90 backdrop-blur-md">
      <div class="max-w-7xl mx-auto w-full px-8 flex items-center justify-between">
        <a href="#" class="flex items-center gap-4 group">
          <div class="text-[#1E3A8A] group-hover:text-[#CC3DAA] transition-colors duration-500">
            <iconify-icon icon="solar:stars-minimalistic-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
          </div>
          <span class="text-xl font-serif font-normal tracking-tight text-[#1E3A8A]">L'Atelier <span class="font-light opacity-70">de Lucette</span></span>
        </a>

        <div class="hidden md:flex items-center gap-12">
          <a href="#histoire" class="text-xs font-medium tracking-widest uppercase text-[#1E3A8A]/80 hover:text-[#1E3A8A] transition-colors">Mon histoire</a>
          <a href="#parcours" class="text-xs font-medium tracking-widest uppercase text-[#1E3A8A]/80 hover:text-[#1E3A8A] transition-colors">Le parcours</a>
          <a href="#methode" class="text-xs font-medium tracking-widest uppercase text-[#1E3A8A]/80 hover:text-[#1E3A8A] transition-colors">La méthode</a>
        </div>

        <div class="flex items-center">
          <a href="#pricing" class="bg-[#CC3DAA] text-[#F7F4EE] text-xs font-medium tracking-widest uppercase px-8 py-4 hover:bg-[#D4845A] transition-all duration-500 rounded-sm">
            Recevoir
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <header class="relative pt-48 pb-32 px-6 overflow-hidden min-h-screen flex flex-col justify-center">
      <div class="absolute inset-0 z-0 select-none">
        <div class="absolute inset-0 bg-gradient-to-b from-[#F7F4EE]/90 via-[#F7F4EE]/70 to-[#F7F4EE] pointer-events-none"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_24%,rgba(49,182,204,0.22)_0%,transparent_28%),radial-gradient(circle_at_84%_18%,rgba(200,58,183,0.18)_0%,transparent_25%),radial-gradient(circle_at_80%_82%,rgba(213,132,88,0.22)_0%,transparent_28%)] pointer-events-none"></div>
      </div>
      <div class="absolute inset-0 bg-grain pointer-events-none z-0 mix-blend-overlay opacity-50"></div>

      <div class="text-center max-w-5xl z-10 mx-auto relative">
        <div class="inline-flex items-center gap-4 mb-12">
          <div class="h-[1px] w-12 bg-[#2AACCB]"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-[#1E3A8A]">Par Caroline Verdier</span>
          <div class="h-[1px] w-12 bg-[#CC3DAA]"></div>
        </div>

        <h1 class="md:text-7xl leading-[1.05] text-5xl font-normal text-[#1E3A8A] tracking-tight font-serif mb-10">
          Deux burn-out m'ont appris<br />
          que j'avançais à côté<br />
          <span class="italic">de ma vie.</span>
        </h1>

        <p class="text-xl md:text-2xl text-[#1E3A8A] max-w-3xl mx-auto mb-6 leading-relaxed font-light italic">
          Je te raconte comment j'ai trouvé ma direction d'âme — et un cadre pour la tenir.
        </p>

        <p class="text-lg md:text-xl text-[#1E3A8A]/78 max-w-3xl mx-auto mb-16 leading-relaxed font-light">
          Un récit audio suivi de deux guides pour reconnaître ta posture et rejoindre ta trajectoire.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <a href="#pricing" class="w-full sm:w-auto px-10 py-5 bg-[#CC3DAA] text-[#F7F4EE] font-medium text-xs uppercase tracking-widest hover:bg-[#D4845A] transition-all hover:-translate-y-1 shadow-2xl shadow-[#CC3DAA]/20 flex items-center justify-center gap-4 group rounded-sm">
            <iconify-icon icon="solar:moon-stars-linear" width="20" height="20" stroke-width="1.5" class="group-hover:text-[#F7F4EE] transition-colors"></iconify-icon>
            Découvrir mon récit
          </a>
          <a href="#histoire" class="w-full sm:w-auto px-10 py-5 bg-transparent border border-[#1E3A8A] text-[#1E3A8A] font-medium text-xs uppercase tracking-widest hover:bg-[#1E3A8A] hover:text-[#F7F4EE] transition-all flex items-center justify-center gap-4 rounded-sm backdrop-blur-sm">
            Mon histoire
          </a>
        </div>

        <!-- Hero card -->
        <div class="mt-32 relative mx-auto max-w-4xl">
          <div class="absolute -top-10 -right-10 w-40 h-40 border border-[#CC3DAA]/20 rounded-full"></div>
          <div class="absolute -bottom-10 -left-10 w-60 h-60 border border-[#1E3A8A]/12 rounded-full"></div>

          <div class="luxury-card p-1 md:p-2 relative overflow-hidden rounded-sm">
            <div class="bg-[#FFFFFF] p-8 md:p-12 grid md:grid-cols-12 gap-12 items-center border border-[#fff]">
              <div class="md:col-span-5 relative">
                <div class="aspect-square bg-[#FFFCF6] border border-[#1E3A8A]/20 flex flex-col items-center justify-center mb-8 relative overflow-hidden rounded-sm">
                  <div class="absolute inset-0 border-[0.5px] border-[#1E3A8A]/12 m-2"></div>
                  <div class="absolute inset-0 border-[0.5px] border-[#1E3A8A]/12 m-4"></div>
                  <iconify-icon icon="solar:stars-minimalistic-linear" class="text-[#CC3DAA]" width="48" height="48" stroke-width="1"></iconify-icon>
                </div>
                <div class="flex justify-between items-end mb-4">
                  <div>
                    <h3 class="text-lg font-serif italic text-[#1E3A8A]">Récit audio guidé</h3>
                    <p class="text-xs uppercase tracking-widest text-[#1E3A8A]/75 mt-1">+ 2 guides offerts</p>
                  </div>
                  <iconify-icon icon="solar:menu-dots-linear" width="20" height="20" class="text-[#1E3A8A]/85" stroke-width="1.5"></iconify-icon>
                </div>
                <div class="h-[1px] w-full bg-[#1E3A8A]/10 mt-6 relative">
                  <div class="absolute left-0 top-0 h-full w-1/3 bg-[#2AACCB]"></div>
                  <div class="absolute left-1/3 top-1/2 -translate-y-1/2 w-2 h-2 bg-[#2AACCB] rounded-full"></div>
                </div>
                <div class="flex justify-between text-[0.65rem] text-[#1E3A8A]/85 font-medium mt-3 tracking-widest">
                  <span>00:00</span>
                  <span>15:00</span>
                </div>
              </div>

              <div class="md:col-span-7 text-left">
                <div class="flex items-center gap-3 text-[#CC3DAA] mb-6">
                  <iconify-icon icon="solar:verified-check-linear" width="16" height="16" stroke-width="1.5" class="text-[#2AACCB]"></iconify-icon>
                  <span class="text-[0.65rem] font-semibold tracking-[0.2em] uppercase text-[#1E3A8A]">Direction d'âme</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#1E3A8A] leading-tight mb-6 tracking-tight">
                  &laquo;&nbsp;J'ai traversé deux burn-out avant de comprendre que ce n'était pas mon rythme le problème.&nbsp;&raquo;
                </h2>
                <p class="text-[#1E3A8A]/80 leading-relaxed text-lg font-light">
                  Je ne te raconte pas ça pour t'impressionner. Je te le raconte parce que peut-être, toi aussi, tu sens un décalage entre la vie que tu mènes et celle qui t'appelle.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Marquee -->
    <section class="py-12 border-y border-[#1E3A8A]/12 bg-white/40 backdrop-blur-sm overflow-hidden">
      <div class="relative w-full overflow-hidden mask-linear-fade">
        <div class="flex whitespace-nowrap animate-marquee">
          <div class="flex items-center gap-24 px-8 opacity-60 text-[#1E3A8A]">
            <span class="text-xl font-serif italic tracking-wide">Rejoindre sa direction</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#CC3DAA]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">Reconnaître les 3 postures</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#CC3DAA]"></iconify-icon>
            <span class="text-xl font-serif">Écouter les signes</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#CC3DAA]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">Avancer sur sa trajectoire</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#CC3DAA]"></iconify-icon>
            <span class="text-xl font-serif italic tracking-wide">Rejoindre sa direction</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#CC3DAA]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">Reconnaître les 3 postures</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#CC3DAA]"></iconify-icon>
            <span class="text-xl font-serif">Écouter les signes</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#CC3DAA]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">Avancer sur sa trajectoire</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section id="problem" class="py-32 px-6 relative">
      <div class="max-w-6xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-24 items-start">
          <div class="sticky top-32">
            <span class="text-[#CC3DAA] font-bold text-[0.65rem] tracking-[0.2em] uppercase mb-6 block">Le problème</span>
            <h2 class="md:text-6xl leading-[1.1] text-5xl text-[#1E3A8A] tracking-tight font-serif mb-8">
              Avancer sans être<br />
              <span class="italic text-[#1E3A8A]/85">sur sa trajectoire.</span>
            </h2>
            <p class="leading-relaxed text-lg font-normal text-[#1E3A8A] mb-12">
              Tu fais tout ce qu'il faut. Tu tiens. Tu gères. Mais au fond, tu sens que quelque chose n'est pas aligné. Tu entends plusieurs voix à la fois, et tu ne sais plus laquelle est la tienne.
            </p>

            <div class="border-l border-[#1E3A8A] pl-8 py-2">
              <p class="text-2xl font-serif italic text-[#1E3A8A] mb-4">
                &laquo;&nbsp;Ce n'est pas que tu n'as pas de direction. C'est que tu n'as pas de cadre pour l'entendre.&nbsp;&raquo;
              </p>
              <p class="text-[0.65rem] text-[#CC3DAA] font-semibold tracking-widest uppercase">&mdash; Caroline</p>
            </div>
          </div>

          <div class="pt-4 space-y-20">
            <div class="group p-8 md:p-10 hover:shadow-lg hover:border-[#CC3DAA]/20 transition-all duration-500 bg-[#C9A96E] border-[#1E3A8A]/12 border rounded-sm shadow-sm">
              <div class="w-12 h-12 flex items-center justify-center border border-[#1E3A8A]/20 rounded-full mb-6 text-[#CC3DAA] bg-[#F7F4EE] group-hover:scale-110 transition-transform duration-500">
                <iconify-icon icon="solar:shield-warning-linear" width="20" height="20" stroke-width="1.5"></iconify-icon>
              </div>
              <h3 class="text-3xl font-serif text-[#1E3A8A] mb-4 tracking-tight">
                Tu fais trop, trop peu, ou à côté
              </h3>
              <p class="text-[#1E3A8A]/85 leading-relaxed text-lg font-light">
                Tu compenses par l'action, tu te protèges par l'inaction, ou tu t'habitues à une vie qui n'est pas la tienne. Dans les trois cas, tu n'es pas sur ta trajectoire. Et ton corps finit par te le dire.
              </p>
            </div>

            <div class="group relative z-20 bg-white p-8 md:p-10 rounded-sm border border-[#2AACCB]/35 shadow-sm hover:shadow-lg hover:border-[#2AACCB]/60 transition-all duration-500">
              <div class="w-12 h-12 flex items-center justify-center border border-[#2AACCB]/45 rounded-full mb-6 text-[#2AACCB] bg-[#F7F4EE] group-hover:scale-110 transition-transform duration-500">
                <iconify-icon icon="solar:refresh-circle-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
              </div>
              <h3 class="text-3xl font-serif text-[#1E3A8A] mb-4 tracking-tight">
                Aucun cadre pour entendre la bonne voix
              </h3>
              <p class="text-[#1E3A8A]/90 leading-relaxed text-lg font-light">
                Tu as accumulé des outils, des lectures, des coachings. Mais il te manque un cadre pour distinguer ce qui est intuition, ce qui est peur, et ce qui est mental — et pour savoir quelle voix te ramène sur ta route.
              </p>
            </div>

            <div class="p-12 bg-[#1E3A8A] text-[#F7F4EE] shadow-2xl relative overflow-hidden rounded-sm mt-10">
              <div class="absolute inset-0 bg-grain opacity-10"></div>
              <div class="absolute top-0 right-0 p-12 opacity-20">
                <iconify-icon icon="solar:stars-minimalistic-linear" width="128" height="128" stroke-width="0.5"></iconify-icon>
              </div>
              <div class="relative z-10">
                <h3 class="text-3xl font-serif italic mb-6 text-white tracking-tight">
                  Rejoins ta direction d'âme
                </h3>
                <p class="leading-relaxed opacity-80 mb-10 text-[#C9A96E] text-lg font-light">
                  Ce récit audio est là pour une chose : te montrer qu'il y a une autre possibilité. Tu n'es pas obligée d'attendre le crash pour écouter ce que tu sais déjà.
                </p>
                <div class="inline-block border border-[#CC3DAA] px-6 py-3 text-[0.65rem] font-semibold text-[#CC3DAA] tracking-[0.2em] uppercase hover:bg-[#CC3DAA] hover:text-[#1E3A8A] transition-colors cursor-default rounded-sm">
                  Trajectoire consciente
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Founder / Mon histoire -->
    <section id="histoire" class="py-32 px-6 bg-[#F7F4EE] border-t border-[#1E3A8A]/20 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-1/3 h-full bg-[#FFFCF6] opacity-50 transform skew-x-12 origin-top-right"></div>
      <div class="max-w-6xl mx-auto relative z-10">
        <div class="flex flex-col md:flex-row gap-16 lg:gap-24 items-center">
          <div class="w-full md:w-5/12 relative group">
            <div class="absolute inset-0 bg-[#CC3DAA] transform translate-x-4 translate-y-4 rounded-sm transition-transform duration-500 group-hover:translate-x-2 group-hover:translate-y-2"></div>
            <div class="aspect-square bg-[#C9A96E] relative overflow-hidden rounded-sm grayscale contrast-110 hover:grayscale-0 transition-all duration-1000 z-10 shadow-xl border border-white/20">
              <img src="/images/portrait-caroline.png" alt="Caroline Verdier" class="w-full h-full object-cover" style="object-position: center 32%;" />
            </div>
            <div class="absolute -bottom-6 -right-6 bg-white p-6 shadow-xl border border-[#1E3A8A]/12 z-20 rounded-sm">
              <iconify-icon icon="solar:stars-minimalistic-linear" class="text-[#CC3DAA]" width="24" height="24"></iconify-icon>
              <p class="text-xs mt-2 uppercase tracking-widest font-semibold text-[#1E3A8A]">Caroline Verdier</p>
            </div>
          </div>

          <div class="w-full md:w-7/12">
            <span class="text-[#CC3DAA] font-bold text-[0.65rem] tracking-[0.2em] uppercase mb-6 block">Mon histoire</span>
            <h2 class="text-4xl md:text-5xl font-serif text-[#1E3A8A] mb-8 tracking-tight leading-[1.1]">
