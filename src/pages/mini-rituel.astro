---
// L'Atelier de Lucette — Page d'inscription gratuite
// Lead magnet : Mini-rituel du discernement
import '../styles/global.css';

const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID || '118700902141020';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mini-rituel gratuit — L'Atelier de Lucette</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNKPGHZL0Y"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SNKPGHZL0Y');
    </script>
    <style>
      :root {
        --color-cream: #F5F0E8;
        --color-bone: #FFFCF6;
        --color-sable: #CDAE72;
        --color-sable-doux: #F1D9A7;
        --color-terre: #D58458;
        --color-terre-fonce: #263F93;
        --color-eau: #31B6CC;
        --color-eau-fonce: #263F93;
        --color-magenta: #C83AB7;
        --color-texte: #263F93;
        --color-texte-doux: #1f2b58;
        --color-blanc: #FFFFFF;
      }
      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background-color: var(--color-cream);
        color: var(--color-texte);
        -webkit-font-smoothing: antialiased;
      }
      button,
      a,
      .ui-text,
      [class*="uppercase"] {
        font-family: 'Special Elite', 'Courier New', monospace;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Cormorant Garamond', serif;
      }
      h1 .italic,
      h2 .italic,
      .script-accent {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
        font-size: 1em;
        line-height: 1;
        display: inline-block;
      }
      .bg-grain {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
      }
      .luxury-card {
        background: rgba(251, 247, 241, 0.4);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(45, 42, 53, 0.08);
        box-shadow: 0 20px 40px -4px rgba(45, 42, 53, 0.05);
      }
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .animate-marquee {
        animation: marquee 40s linear infinite;
      }
      .mask-linear-fade {
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
      }
      .flip-card {
        perspective: 1000px;
      }
      .flip-card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        transition: transform 0.7s ease-out;
        transform-style: preserve-3d;
      }
      @media (prefers-reduced-motion: no-preference) {
        .flip-card:hover .flip-card-inner,
        .flip-card:focus-within .flip-card-inner {
          transform: rotateY(180deg);
        }
      }
      .flip-card-front,
      .flip-card-back {
        position: absolute;
        inset: 0;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
        border-radius: 1rem;
        overflow: hidden;
      }
      .flip-card-back {
        transform: rotateY(180deg);
      }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-thumb { background: var(--color-sable-doux); border-radius: 0; }

      /* MailerLite form */
      .ml-form-embedSubmitLoad { display: inline-block; width: 20px; height: 20px; }
      .ml-form-embedSubmitLoad:after { content: " "; display: block; width: 11px; height: 11px; margin: 4px auto; border-radius: 50%; border: 3px solid #fff; border-color: #fff #fff #fff transparent; animation: ml-spin 1.2s linear infinite; }
      @keyframes ml-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
      .ml-error input { border-color: #C83AB7 !important; }
      .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
    </style>

    <script is:inline src="https://groot.mailerlite.com/js/w/webforms.min.js?v83147fa8ce2d95cb73ece7f28b469519" defer></script>

    {metaPixelId && (
      <script define:vars={{ metaPixelId }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', metaPixelId);
        fbq('track', 'PageView');
      </script>
    )}
  </head>

  <body class="selection:bg-[#C83AB7] selection:text-[#F5F0E8] relative overflow-x-hidden text-lg">
    {metaPixelId && (
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    )}

    <!-- Geometrie de fond -->
    <div class="arch-lines">
      <svg width="100%" height="100%" viewBox="0 0 1440 900" preserveAspectRatio="none">
        <line x1="10%" y1="0" x2="10%" y2="100%" stroke="#263F93" stroke-width="0.5" />
        <line x1="90%" y1="0" x2="90%" y2="100%" stroke="#263F93" stroke-width="0.5" />
        <line x1="50%" y1="0" x2="50%" y2="100%" stroke="#263F93" stroke-width="0.5" stroke-dasharray="4 8" />
        <line x1="0" y1="800" x2="1440" y2="400" stroke="#C83AB7" stroke-width="0.5" opacity="0.55" />
      </svg>
    </div>

    <!-- Navigation -->
    <nav class="fixed top-0 inset-x-0 z-50 h-24 flex items-center border-b border-[#263F93]/20 bg-[#F5F0E8]/90 backdrop-blur-md">
      <div class="max-w-7xl mx-auto w-full px-8 flex items-center justify-between">
        <a href="#" class="flex items-center gap-4 group">
          <div class="text-[#263F93] group-hover:text-[#C83AB7] transition-colors duration-500">
            <iconify-icon icon="solar:stars-minimalistic-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
          </div>
          <span class="text-xl font-serif font-normal tracking-tight text-[#263F93]">L'Atelier <span class="font-light opacity-70">de Lucette</span></span>
        </a>

        <div class="hidden md:flex items-center gap-12">
          <a href="#methode" class="text-xs font-medium tracking-widest uppercase text-[#263F93]/80 hover:text-[#263F93] transition-colors">La méthode</a>
          <a href="#rituel" class="text-xs font-medium tracking-widest uppercase text-[#263F93]/80 hover:text-[#263F93] transition-colors">Le rituel</a>
          <a href="#histoire" class="text-xs font-medium tracking-widest uppercase text-[#263F93]/80 hover:text-[#263F93] transition-colors">Mon histoire</a>
        </div>

        <div class="flex items-center">
          <a href="#pricing" class="bg-[#C83AB7] text-[#F5F0E8] text-xs font-medium tracking-widest uppercase px-8 py-4 hover:bg-[#D58458] transition-all duration-500 rounded-sm">
            Recevoir
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <header class="relative pt-48 pb-32 px-6 overflow-hidden min-h-screen flex flex-col justify-center">
      <div class="absolute inset-0 z-0 select-none">
        <div class="absolute inset-0 bg-gradient-to-b from-[#F5F0E8]/90 via-[#F5F0E8]/70 to-[#F5F0E8] pointer-events-none"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_24%,rgba(49,182,204,0.22)_0%,transparent_28%),radial-gradient(circle_at_84%_18%,rgba(200,58,183,0.18)_0%,transparent_25%),radial-gradient(circle_at_80%_82%,rgba(213,132,88,0.22)_0%,transparent_28%)] pointer-events-none"></div>
      </div>
      <div class="absolute inset-0 bg-grain pointer-events-none z-0 mix-blend-overlay opacity-50"></div>

      <div class="text-center max-w-5xl z-10 mx-auto relative">
        <div class="inline-flex items-center gap-4 mb-12">
          <div class="h-[1px] w-12 bg-[#31B6CC]"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-[#263F93]">Créé par Caroline Verdier</span>
          <div class="h-[1px] w-12 bg-[#C83AB7]"></div>
        </div>

        <h1 class="md:text-7xl leading-[1.05] text-5xl font-normal text-[#263F93] tracking-tight font-serif mb-10">
          Ton intuition chuchote,<br />
          ta peur crie,<br />
          ton mental analyse tout.
        </h1>

        <p class="text-xl md:text-2xl text-[#263F93] max-w-3xl mx-auto mb-6 leading-relaxed font-light italic">
          Pas étonnant que tu ne saches plus qui écouter.
        </p>

        <p class="text-lg md:text-xl text-[#263F93]/78 max-w-3xl mx-auto mb-16 leading-relaxed font-light">
          Un mini-rituel guidé pour remettre de l'ordre et retrouver une action juste.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <a href="#pricing" class="w-full sm:w-auto px-10 py-5 bg-[#C83AB7] text-[#F5F0E8] font-medium text-xs uppercase tracking-widest hover:bg-[#D58458] transition-all hover:-translate-y-1 shadow-2xl shadow-[#C83AB7]/20 flex items-center justify-center gap-4 group rounded-sm">
            <iconify-icon icon="solar:moon-stars-linear" width="20" height="20" stroke-width="1.5" class="group-hover:text-[#F5F0E8] transition-colors"></iconify-icon>
            Recevoir le mini-rituel gratuit
          </a>
          <a href="#methode" class="w-full sm:w-auto px-10 py-5 bg-transparent border border-[#263F93] text-[#263F93] font-medium text-xs uppercase tracking-widest hover:bg-[#263F93] hover:text-[#F5F0E8] transition-all flex items-center justify-center gap-4 rounded-sm backdrop-blur-sm">
            La méthode
          </a>
        </div>

        <!-- Hero card -->
        <div class="mt-32 relative mx-auto max-w-4xl">
          <div class="absolute -top-10 -right-10 w-40 h-40 border border-[#C83AB7]/20 rounded-full"></div>
          <div class="absolute -bottom-10 -left-10 w-60 h-60 border border-[#263F93]/12 rounded-full"></div>

          <div class="luxury-card p-1 md:p-2 relative overflow-hidden rounded-sm">
            <div class="bg-[#FFFFFF] p-8 md:p-12 grid md:grid-cols-12 gap-12 items-center border border-[#fff]">
              <div class="md:col-span-5 relative">
                <div class="aspect-square bg-[#FFFCF6] border border-[#263F93]/20 flex flex-col items-center justify-center mb-8 relative overflow-hidden rounded-sm">
                  <div class="absolute inset-0 border-[0.5px] border-[#263F93]/12 m-2"></div>
                  <div class="absolute inset-0 border-[0.5px] border-[#263F93]/12 m-4"></div>
                  <iconify-icon icon="solar:stars-minimalistic-linear" class="text-[#C83AB7]" width="48" height="48" stroke-width="1"></iconify-icon>
                </div>
                <div class="flex justify-between items-end mb-4">
                  <div>
                    <h3 class="text-lg font-serif italic text-[#263F93]">Mini-Rituel guidé</h3>
                    <p class="text-xs uppercase tracking-widest text-[#263F93]/75 mt-1">L'Atelier de Lucette</p>
                  </div>
                  <iconify-icon icon="solar:menu-dots-linear" width="20" height="20" class="text-[#263F93]/85" stroke-width="1.5"></iconify-icon>
                </div>
                <div class="h-[1px] w-full bg-[#263F93]/10 mt-6 relative">
                  <div class="absolute left-0 top-0 h-full w-1/3 bg-[#31B6CC]"></div>
                  <div class="absolute left-1/3 top-1/2 -translate-y-1/2 w-2 h-2 bg-[#31B6CC] rounded-full"></div>
                </div>
                <div class="flex justify-between text-[0.65rem] text-[#263F93]/85 font-medium mt-3 tracking-widest">
                  <span>00:00</span>
                  <span>15:00</span>
                </div>
              </div>

              <div class="md:col-span-7 text-left">
                <div class="flex items-center gap-3 text-[#C83AB7] mb-6">
                  <iconify-icon icon="solar:verified-check-linear" width="16" height="16" stroke-width="1.5" class="text-[#31B6CC]"></iconify-icon>
                  <span class="text-[0.65rem] font-semibold tracking-[0.2em] uppercase text-[#263F93]">Discernement intuitif</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#263F93] leading-tight mb-6 tracking-tight">
                  &laquo;&nbsp;L'intuition ne crie pas. Elle chuchote.&nbsp;&raquo;
                </h2>
                <p class="text-[#263F93]/80 leading-relaxed text-lg font-light">
                  Tu n'as pas besoin d'apprendre &agrave; &ecirc;tre intuitive. Tu l'es d&eacute;j&agrave;. Tu as juste besoin d'un cadre pour faire le tri entre ce qui est un vrai signal, ce qui est une peur, et ce qui est un bruit mental.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Marquee -->
    <section class="py-12 border-y border-[#263F93]/12 bg-white/40 backdrop-blur-sm overflow-hidden">
      <div class="relative w-full overflow-hidden mask-linear-fade">
        <div class="flex whitespace-nowrap animate-marquee">
          <div class="flex items-center gap-24 px-8 opacity-60 text-[#263F93]">
            <span class="text-xl font-serif italic tracking-wide">Revenir au corps</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#C83AB7]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">&Eacute;couter l'intuition</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#C83AB7]"></iconify-icon>
            <span class="text-xl font-serif">Faire le tri</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#C83AB7]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">Poser une action juste</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#C83AB7]"></iconify-icon>
            <span class="text-xl font-serif italic tracking-wide">Revenir au corps</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#C83AB7]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">&Eacute;couter l'intuition</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#C83AB7]"></iconify-icon>
            <span class="text-xl font-serif">Faire le tri</span>
            <iconify-icon icon="solar:star-linear" width="12" class="text-[#C83AB7]"></iconify-icon>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">Poser une action juste</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section id="problem" class="py-32 px-6 relative">
      <div class="max-w-6xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-24 items-start">
          <div class="sticky top-32">
            <span class="text-[#C83AB7] font-bold text-[0.65rem] tracking-[0.2em] uppercase mb-6 block">Le probl&egrave;me</span>
            <h2 class="md:text-6xl leading-[1.1] text-5xl text-[#263F93] tracking-tight font-serif mb-8">
              Fonctionner &agrave; l'ext&eacute;rieur.<br />
              <span class="italic text-[#263F93]/85">Douter &agrave; l'int&eacute;rieur.</span>
            </h2>
            <p class="leading-relaxed text-lg font-normal text-[#263F93] mb-12">
              Depuis des ann&eacute;es, tu fais &laquo;&nbsp;tout ce qu'il faut&nbsp;&raquo;. Tu lis, tu apprends, tu cherches. Mais au fond, tu sens que quelque chose ne passe pas. Tu entends tout en m&ecirc;me temps : ton mental qui analyse, ta peur qui te freine, et une petite voix que tu n'oses pas suivre.
            </p>

            <div class="border-l border-[#263F93] pl-8 py-2">
              <p class="text-2xl font-serif italic text-[#263F93] mb-4">
                &laquo;&nbsp;Le probl&egrave;me n'est pas que tu n'as pas d'intuition. Le probl&egrave;me, c'est que tu n'as pas de syst&egrave;me pour faire le tri.&nbsp;&raquo;
              </p>
              <p class="text-[0.65rem] text-[#C83AB7] font-semibold tracking-widest uppercase">&mdash; Caroline</p>
            </div>
          </div>

          <div class="pt-4 space-y-20">
            <div class="group p-8 md:p-10 hover:shadow-lg hover:border-[#C83AB7]/20 transition-all duration-500 bg-[#CDAE72] border-[#263F93]/12 border rounded-sm shadow-sm">
              <div class="w-12 h-12 flex items-center justify-center border border-[#263F93]/20 rounded-full mb-6 text-[#C83AB7] bg-[#F5F0E8] group-hover:scale-110 transition-transform duration-500">
                <iconify-icon icon="solar:shield-warning-linear" width="20" height="20" stroke-width="1.5"></iconify-icon>
              </div>
              <h3 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">
                Les 3 voix qui parlent en m&ecirc;me temps
              </h3>
              <p class="text-[#263F93]/85 leading-relaxed text-lg font-light">
                L'intuition chuchote. La peur crie. Le mental analyse tout. Quand tu entends trois voix &agrave; la fois, tu ne sais plus laquelle est la tienne. Et &agrave; force de ne pas savoir, tu ne fais rien, ou tu fais au hasard.
              </p>
            </div>

            <div class="group relative z-20 bg-white p-8 md:p-10 rounded-sm border border-[#31B6CC]/35 shadow-sm hover:shadow-lg hover:border-[#31B6CC]/60 transition-all duration-500">
              <div class="w-12 h-12 flex items-center justify-center border border-[#31B6CC]/45 rounded-full mb-6 text-[#31B6CC] bg-[#F5F0E8] group-hover:scale-110 transition-transform duration-500">
                <iconify-icon icon="solar:refresh-circle-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
              </div>
              <h3 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">
                Aucun cadre pour discerner
              </h3>
              <p class="text-[#263F93]/90 leading-relaxed text-lg font-light">
                Tu as accumul&eacute; des outils, des lectures, des m&eacute;ditations. Mais il te manque un cadre simple pour poser une question, &eacute;couter les signaux de ton corps, utiliser ton oracle comme un vrai miroir, et repartir avec une prochaine action concr&egrave;te.
              </p>
            </div>

            <div class="p-12 bg-[#263F93] text-[#F5F0E8] shadow-2xl relative overflow-hidden rounded-sm mt-10">
              <div class="absolute inset-0 bg-grain opacity-10"></div>
              <div class="absolute top-0 right-0 p-12 opacity-20">
                <iconify-icon icon="solar:stars-minimalistic-linear" width="128" height="128" stroke-width="0.5"></iconify-icon>
              </div>
              <div class="relative z-10">
                <h3 class="text-3xl font-serif italic mb-6 text-white tracking-tight">
                  Reviens &agrave; toi
                </h3>
                <p class="leading-relaxed opacity-80 mb-10 text-[#CDAE72] text-lg font-light">
                  Ce mini-rituel est l&agrave; pour tester une promesse simple : est-ce qu'en 15 minutes, avec une question vraie, un oracle et un cadre, tu peux retrouver une action juste ?
                </p>
                <div class="inline-block border border-[#C83AB7] px-6 py-3 text-[0.65rem] font-semibold text-[#C83AB7] tracking-[0.2em] uppercase hover:bg-[#C83AB7] hover:text-[#263F93] transition-colors cursor-default rounded-sm">
                  Clart&eacute; sans force
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Method -->
    <section class="overflow-hidden bg-[#F5F0E8] border-[#263F93]/12 border-t py-32 px-6" id="methode">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-24">
          <span class="text-[#C83AB7] font-bold text-[0.65rem] tracking-[0.2em] uppercase mb-4 block">La m&eacute;thode</span>
          <h2 class="text-4xl md:text-5xl font-serif text-[#263F93] tracking-tight">Les 3 piliers du discernement</h2>
          <p class="text-[#263F93]/80 mt-6 max-w-xl mx-auto font-light">
            Un cadre en 3 mouvements pour passer du brouillard &agrave; l'action juste.
          </p>
        </div>

        <div class="flex flex-col md:flex-row md:gap-10 gap-12 items-center justify-center">
          <!-- Corps -->
          <div class="flip-card w-full max-w-[330px] aspect-[2/3] cursor-pointer z-20 group">
            <div class="flip-card-inner">
              <div class="flip-card-front">
                <div class="absolute inset-0 bg-[#263F93] rounded-2xl overflow-hidden shadow-2xl">
                  <div class="w-full h-full object-cover opacity-40 scale-110 group-hover:scale-100 transition-transform duration-1000 bg-gradient-to-b from-[#C83AB7] to-[#263F93]"></div>
                  <div class="absolute inset-0 bg-gradient-to-t from-[#263F93] via-transparent to-transparent opacity-90"></div>
                </div>
                <div class="absolute inset-x-4 top-4 bottom-4 bg-white/5 backdrop-blur-md rounded-xl border border-white/10 p-6 flex flex-col justify-between">
                  <div class="flex justify-between items-start">
                    <div class="w-12 h-12 bg-[#C83AB7] rounded-full flex items-center justify-center text-[#263F93] shadow-lg shadow-[#C83AB7]/20">
                      <iconify-icon icon="solar:heart-pulse-linear" width="24" height="24"></iconify-icon>
                    </div>
                    <span class="text-[0.6rem] font-bold text-[#F5F0E8] uppercase tracking-[0.2em] border border-white/20 px-2 py-1 rounded-sm">Pilier 1</span>
                  </div>
                  <div>
                    <h3 class="text-2xl font-serif text-white leading-tight mb-2">Le Corps</h3>
