---
import '../styles/global.css';

const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID || '118700902141020';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mentions légales — L'Atelier de Lucette</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --color-cream: #F5F0E8;
        --color-bone: #FFFCF6;
        --color-sable: #CDAE72;
        --color-sable-doux: #F1D9A7;
        --color-terre: #D58458;
        --color-terre-fonce: #263F93;
        --color-eau: #31B6CC;
        --color-eau-fonce: #263F93;
        --color-magenta: #C83AB7;
        --color-texte: #263F93;
        --color-texte-doux: #1f2b58;
        --color-blanc: #FFFFFF;
      }
      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background-color: var(--color-cream);
        color: var(--color-texte);
        -webkit-font-smoothing: antialiased;
      }
      button, a, .ui-text, [class*="uppercase"] {
        font-family: 'Special Elite', 'Courier New', monospace;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Cormorant Garamond', serif;
      }
      h1 .italic, h2 .italic {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
      }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-thumb { background: var(--color-sable-doux); border-radius: 0; }
    </style>
  </head>

  <body class="selection:bg-[#C83AB7] selection:text-[#F5F0E8] text-lg">
    <!-- Navigation -->
    <nav class="fixed top-0 inset-x-0 z-50 h-24 flex items-center border-b border-[#263F93]/20 bg-[#F5F0E8]/90 backdrop-blur-md">
      <div class="max-w-7xl mx-auto w-full px-8 flex items-center justify-between">
        <a href="/" class="flex items-center gap-4 group">
          <div class="text-[#263F93] group-hover:text-[#C83AB7] transition-colors duration-500">
            <iconify-icon icon="solar:stars-minimalistic-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
          </div>
          <span class="text-xl font-serif font-normal tracking-tight text-[#263F93]">L'Atelier <span class="font-light opacity-70">de Lucette</span></span>
        </a>

        <div class="flex items-center">
          <a href="/#pricing" class="bg-[#C83AB7] text-[#F5F0E8] text-xs font-medium tracking-widest uppercase px-8 py-4 hover:bg-[#D58458] transition-all duration-500 rounded-sm">
            Recevoir
          </a>
        </div>
      </div>
    </nav>

    <!-- Content -->
    <main class="pt-40 pb-32 px-6 max-w-4xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex items-center gap-4 mb-8">
          <div class="h-[1px] w-12 bg-[#C83AB7]"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-[#C83AB7]">Infos l&eacute;gales</span>
        </div>
        <h1 class="text-5xl md:text-6xl font-serif text-[#263F93] tracking-tight leading-[1.1]">
          Mentions l&eacute;gales
        </h1>
      </div>

      <div class="space-y-12 text-[#263F93]/85 leading-relaxed font-light">
        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">1. Identit&eacute; de l'&eacute;ditrice</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm space-y-2">
            <p><strong class="font-medium">Nom :</strong> Caroline Verdier</p>
            <p><strong class="font-medium">Adresse :</strong> Genève, Suisse</p>
            <p><strong class="font-medium">Email :</strong> <a href="mailto:hello@carolineverdier.com" class="text-[#C83AB7] hover:underline">hello@carolineverdier.com</a></p>
            <p><strong class="font-medium">Num&eacute;ro IDE :</strong> CHE-448.630.437</p>
            <p><strong class="font-medium">TVA :</strong> Non assujettie (art. 10 LTVA)</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">2. Directrice de la publication</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>Caroline Verdier</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">3. H&eacute;bergement</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm space-y-2">
            <p><strong class="font-medium">H&eacute;bergeur :</strong> Cloudflare, Inc.</p>
            <p><strong class="font-medium">Adresse :</strong> 101 Townsend Street, San Francisco, CA 94107, &Eacute;tats-Unis</p>
            <p><strong class="font-medium">Site web :</strong> <a href="https://www.cloudflare.com" class="text-[#C83AB7] hover:underline" target="_blank" rel="noopener">www.cloudflare.com</a></p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">4. Propri&eacute;t&eacute; intellectuelle</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>
              L'ensemble des contenus pr&eacute;sents sur le site <a href="https://latelierdelucette.com" class="text-[#C83AB7] hover:underline">latelierdelucette.com</a> (textes, images, illustrations, vid&eacute;os, cartes oracle, design) est la propri&eacute;t&eacute; exclusive de Caroline Verdier, sauf indication contraire. Toute reproduction, repr&eacute;sentation, modification ou exploitation, totale ou partielle, sans autorisation pr&eacute;alable est interdite.
            </p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">5. Donn&eacute;es personnelles</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm space-y-4">
            <p>
              Les donn&eacute;es collect&eacute;es via le formulaire d'inscription (nom, email) sont trait&eacute;es par MailerLite dans le seul but de vous envoyer le mini-rituel gratuit et les communications de L'Atelier de Lucette. Vous pouvez vous d&eacute;sinscrire &agrave; tout moment via le lien de d&eacute;sabonnement pr&eacute;sent dans chaque email.
            </p>
            <p>
              Conform&eacute;ment au RGPD, vous disposez d'un droit d'acc&egrave;s, de rectification et de suppression de vos donn&eacute;es. Pour l'exercer, &eacute;crivez &agrave; <a href="mailto:hello@carolineverdier.com" class="text-[#C83AB7] hover:underline">hello@carolineverdier.com</a>.
            </p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">6. Cookies</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>
              Ce site utilise un pixel Meta (Facebook) pour mesurer l'audience et suivre les conversions. Aucun cookie tiers suppl&eacute;mentaire n'est d&eacute;pos&eacute; sans votre consentement.
            </p>
          </div>
        </section>
      </div>
    </main>

    <!-- Footer -->
    <footer class="py-16 px-6 bg-[#263F93] border-t border-white/5">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">
          <a href="/" class="flex items-center gap-4 group">
            <iconify-icon icon="solar:stars-minimalistic-linear" class="text-[#C83AB7] group-hover:text-[#D58458] transition-colors" width="20" height="20" stroke-width="1.5"></iconify-icon>
            <span class="text-white font-serif text-lg">L'Atelier <span class="font-light opacity-60">de Lucette</span></span>
          </a>

          <div class="flex items-center gap-12 text-xs uppercase tracking-widest text-white/70">
            <a href="/" class="hover:text-[#C83AB7] transition-colors">M&eacute;thode</a>
            <a href="/#rituel" class="hover:text-[#C83AB7] transition-colors">Rituel</a>
            <a href="/#histoire" class="hover:text-[#C83AB7] transition-colors">Histoire</a>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-xs text-white/65 font-light tracking-wide">
            &copy; 2026 L'Atelier de Lucette. Tous droits r&eacute;serv&eacute;s.
            <span class="mx-2 opacity-40">|</span>
            <a href="/mentions-legales" class="hover:text-[#C83AB7] transition-colors">Mentions l&eacute;gales</a>
            <span class="mx-2 opacity-40">|</span>
            <a href="/cgv" class="hover:text-[#C83AB7] transition-colors">CGV</a>
          </p>
          <p class="text-[0.6rem] text-white/55 uppercase tracking-widest font-light">
            Discernement &mdash; Intuition &mdash; Action
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
