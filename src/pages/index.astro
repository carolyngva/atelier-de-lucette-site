---
import '../styles/global.css';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>L'Atelier de Lucette</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNKPGHZL0Y"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (window.location.search.includes('tr=internal')) {
        try { localStorage.setItem('__internal', '1'); } catch(e) {}
      }
      var __int = false;
      try { __int = localStorage.getItem('__internal') === '1'; } catch(e) {}
      gtag('config', 'G-SNKPGHZL0Y', __int ? { 'traffic_type': 'internal' } : {});
    </script>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Cormorant Garamond', Georgia, serif;
        background-color: #F7F4EE;
        color: #1E3A8A;
        -webkit-font-smoothing: antialiased;
      }
      .ui-text { font-family: 'Special Elite', 'Courier New', monospace; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <div class="max-w-lg">
      <div class="w-16 h-16 mx-auto mb-8 rounded-full bg-[#CC3DAA]/10 flex items-center justify-center">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#CC3DAA" stroke-width="1.5">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <h1 class="text-5xl md:text-6xl font-serif font-medium tracking-tight mb-6">
        L'Atelier<br />
        <span class="text-[#CC3DAA] italic">de Lucette</span>
      </h1>
      <p class="text-xl text-[#1E3A8A]/80 font-light mb-10 leading-relaxed">
        Un espace pour revenir à toi, écouter ton intuition,<br class="hidden sm:block" />
        et poser des actions justes.
      </p>
      <a
        href="/mini-rituel"
        class="ui-text inline-block px-10 py-5 bg-[#CC3DAA] text-[#F7F4EE] text-xs uppercase tracking-widest font-medium hover:bg-[#D4845A] transition-all rounded-sm"
      >
        Découvrir le mini-rituel gratuit
      </a>
    </div>
  </body>
</html>
