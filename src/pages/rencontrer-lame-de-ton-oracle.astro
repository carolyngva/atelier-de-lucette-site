---
import '../styles/global.css';

const passages = [
  {
    number: '01',
    title: "Rencontrer l'énergie de ton oracle",
    text: "Sentir sa présence, son atmosphère, son mouvement, avant de chercher à l'expliquer.",
  },
  {
    number: '02',
    title: 'Connecter à ton projet de création',
    text: "Entrer dans le lien vivant avec le jeu qui veut naître et ouvrir l'espace de sa mise en matière.",
  },
  {
    number: '03',
    title: 'Recevoir les messages de ton oracle',
    text: "Laisser venir les mots, les sensations et les messages sans les filtrer trop vite avec le mental.",
  },
  {
    number: '04',
    title: 'Ramener des visions',
    text: "Continuer à recevoir les images, les symboles, les cartes et les facettes de ton univers.",
  },
  {
    number: '05',
    title: 'Faire descendre le nom de ton oracle',
    text: "Écouter le nom juste comme une vibration, pas comme un exercice marketing à réussir.",
  },
  {
    number: '06',
    title: 'Découvrir sa place dans le monde',
    text: "Clarifier la transformation que ton oracle vient accompagner et le domaine où il veut agir.",
  },
];
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rencontrer l'âme de ton oracle - L'Atelier de Lucette</title>
    <meta
      name="description"
      content="Une méthode intuitive en 6 guidances pour écouter l'énergie de l'oracle qui veut naître à travers toi, recevoir son essence et poser les premières graines de sa mise en matière."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNKPGHZL0Y"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (window.location.search.includes('tr=internal')) {
        try { localStorage.setItem('__internal', '1'); } catch(e) {}
      }
      var __int = false;
      try { __int = localStorage.getItem('__internal') === '1'; } catch(e) {}
      gtag('config', 'G-SNKPGHZL0Y', __int ? { 'traffic_type': 'internal' } : {});
    </script>
  </head>

  <body class="selection:bg-[#CC3DAA] selection:text-[#F7F4EE] overflow-x-hidden bg-[#F7F4EE] text-[#1E3A8A]">
    <div class="bg-grain fixed inset-0 pointer-events-none z-0"></div>
    <div class="arch-lines">
      <svg width="100%" height="100%" viewBox="0 0 1440 900" preserveAspectRatio="none">
        <line x1="10%" y1="0" x2="10%" y2="100%" stroke="#1E3A8A" stroke-width="0.5" />
        <line x1="90%" y1="0" x2="90%" y2="100%" stroke="#1E3A8A" stroke-width="0.5" />
        <line x1="0" y1="800" x2="1440" y2="360" stroke="#CC3DAA" stroke-width="0.5" opacity="0.5" />
      </svg>
    </div>

    <nav class="fixed top-0 inset-x-0 z-50 h-20 flex items-center border-b border-[#1E3A8A]/15 bg-[#F7F4EE]/90 backdrop-blur-md">
      <div class="max-w-7xl mx-auto w-full px-6 flex items-center justify-between">
        <a href="/" class="text-xl font-serif tracking-tight text-[#1E3A8A]">L'Atelier <span class="opacity-70">de Lucette</span></a>
        <div class="hidden md:flex items-center gap-9">
          <a href="#passages" class="ui-text text-xs tracking-[0.2em] uppercase text-[#1E3A8A]/70 hover:text-[#CC3DAA] transition-colors">Les passages</a>
          <a href="#prix" class="ui-text text-xs tracking-[0.2em] uppercase text-[#1E3A8A]/70 hover:text-[#CC3DAA] transition-colors">Prix</a>
        </div>
        <a href="#prix" class="bg-[#CC3DAA] text-[#F7F4EE] ui-text text-xs tracking-[0.18em] uppercase px-5 py-3 rounded-sm hover:bg-[#D4845A] transition-colors">Commencer</a>
      </div>
    </nav>

    <main class="relative z-10">
      <header class="min-h-screen flex items-center px-6 pt-28 pb-20">
        <div class="max-w-6xl mx-auto grid lg:grid-cols-[1.15fr_0.85fr] gap-12 items-center">
          <section>
            <div class="inline-flex items-center gap-4 mb-8">
              <div class="h-px w-10 bg-[#2AACCB]"></div>
              <span class="ui-text text-xs tracking-[0.22em] uppercase text-[#1E3A8A]/70">Méthode intuitive</span>
              <div class="h-px w-10 bg-[#CC3DAA]"></div>
            </div>
            <h1 class="text-5xl md:text-7xl leading-[1.02] font-normal tracking-tight mb-8">
              Rencontrer l'âme<br />de ton oracle
            </h1>
            <p class="text-xl md:text-2xl leading-relaxed italic text-[#1E3A8A]/80 mb-8 max-w-3xl">
              Une méthode intuitive en 6 guidances pour écouter l'énergie de l'oracle qui veut naître à travers toi, recevoir son essence, clarifier son message et poser les premières graines de sa mise en matière.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#prix" class="inline-flex justify-center bg-[#CC3DAA] text-[#F7F4EE] ui-text text-xs tracking-[0.18em] uppercase px-8 py-4 rounded-sm hover:bg-[#D4845A] transition-colors">Commencer le rituel</a>
              <a href="/rencontrer-ton-oracle" class="inline-flex justify-center border border-[#1E3A8A]/25 text-[#1E3A8A] ui-text text-xs tracking-[0.18em] uppercase px-8 py-4 rounded-sm hover:border-[#CC3DAA] hover:text-[#CC3DAA] transition-colors">Essayer la guidance offerte</a>
            </div>
          </section>

          <aside class="luxury-card bg-[#FFFCF6]/85 border border-[#1E3A8A]/10 rounded-sm p-7 md:p-8">
            <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#CC3DAA] mb-5">Ce que tu reçois</p>
            <ul class="space-y-4 text-lg text-[#1E3A8A]/80">
              <li class="flex gap-3"><span class="text-[#CC3DAA]">*</span><span>6 guidances audio courtes, entre 5 et 12 minutes.</span></li>
              <li class="flex gap-3"><span class="text-[#CC3DAA]">*</span><span>6 fiches d'auto-coaching pour noter ce qui émerge.</span></li>
              <li class="flex gap-3"><span class="text-[#CC3DAA]">*</span><span>L'ebook bonus <em>Crée ton Oracle</em> en support complémentaire.</span></li>
              <li class="flex gap-3"><span class="text-[#CC3DAA]">*</span><span>Un parcours à refaire autant de fois que nécessaire.</span></li>
            </ul>
          </aside>
        </div>
      </header>

      <section class="px-6 py-24 bg-[#FFFCF6] border-y border-[#1E3A8A]/10">
        <div class="max-w-4xl mx-auto text-center">
          <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#CC3DAA] mb-6">Le vrai blocage</p>
          <h2 class="text-4xl md:text-5xl leading-tight font-normal mb-8">
            Tu sens qu'un oracle t'appelle, mais dès que tu veux le construire, ton mental prend toute la place.
          </h2>
          <p class="text-xl leading-relaxed text-[#1E3A8A]/75">
            Tu cherches le bon nombre de cartes, le bon thème, le bon nom, la bonne structure. Et quelque chose se fige. Ce parcours t'invite à revenir avant la stratégie : au lien vivant avec l'oracle lui-même.
          </p>
        </div>
      </section>

      <section class="px-6 py-24">
        <div class="max-w-5xl mx-auto grid md:grid-cols-[0.8fr_1.2fr] gap-12 items-center">
          <div>
            <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#2AACCB] mb-6">Le repositionnement</p>
            <h2 class="text-4xl md:text-5xl leading-tight font-normal mb-6">Ton oracle n'a pas besoin d'être inventé.</h2>
            <p class="text-3xl italic leading-tight text-[#CC3DAA]">Il peut d'abord être rencontré.</p>
          </div>
          <div class="text-lg md:text-xl leading-relaxed text-[#1E3A8A]/75 space-y-5">
            <p>Ce mini-parcours n'est pas une formation technique pour fabriquer un jeu de cartes, choisir un imprimeur ou lancer une campagne de vente.</p>
            <p>C'est une méthode intuitive pour entrer en relation avec l'âme de ton oracle et laisser sa forme se préciser depuis l'intérieur.</p>
          </div>
        </div>
      </section>

      <section class="px-6 py-24 bg-[#FFFCF6] border-y border-[#1E3A8A]/10">
        <div class="max-w-5xl mx-auto grid md:grid-cols-[0.9fr_1.1fr] gap-12 items-center">
          <div>
            <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#CC3DAA] mb-6">Pourquoi je te propose ça</p>
            <h2 class="text-4xl md:text-5xl leading-tight font-normal mb-6">J'ai créé mon oracle en l'écoutant avant de le construire.</h2>
          </div>
          <div class="text-lg md:text-xl leading-relaxed text-[#1E3A8A]/75 space-y-5">
            <p>Je suis Caroline Verdier, créatrice de l'oracle <em>D'une Rive à l'Autre</em>. Quand ce jeu est né, je ne suis pas partie d'un plan parfait. J'ai d'abord écouté son énergie, ses images, ses cartes, ce qu'il venait transformer en moi.</p>
            <p>Ce parcours vient de cette expérience : accompagner la naissance d'un oracle comme un passage intérieur, puis seulement ensuite comme un objet à mettre en matière.</p>
            <p>Ces guidances viennent aussi de mon accompagnement <em>Crée ton Oracle</em>, où elles ont permis à des femmes de créer leur propre oracle dans un cadre accompagné. Je les propose ici en version autonome, pour t'aider à ouvrir le processus à ton rythme.</p>
          </div>
        </div>
      </section>

      <section id="passages" class="px-6 py-24 bg-[#1E3A8A] text-[#F7F4EE]">
        <div class="max-w-6xl mx-auto">
          <div class="text-center max-w-3xl mx-auto mb-14">
            <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#C9A96E] mb-6">Les 6 passages</p>
            <h2 class="text-4xl md:text-5xl leading-tight font-normal mb-6">Un rituel à suivre dans l'ordre, puis à reprendre selon ce qui demande à naître.</h2>
            <p class="text-xl leading-relaxed text-[#F1D9A7]">Chaque guidance peut être refaite autant de fois que nécessaire. Le parcours accompagne une écoute qui se précise avec le temps.</p>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
            {passages.map((passage) => (
              <article class="bg-white/7 border border-white/10 rounded-sm p-6">
                <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#CC3DAA] mb-5">{passage.number}</p>
                <h3 class="text-2xl font-normal text-white mb-3">{passage.title}</h3>
                <p class="leading-relaxed text-[#F1D9A7]/90">{passage.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="px-6 py-24 bg-[#FFFCF6]">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8">
          <article class="p-7 md:p-8 bg-[#F7F4EE] border border-[#1E3A8A]/10 rounded-sm">
            <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#2AACCB] mb-5">Pour toi si...</p>
            <ul class="space-y-4 text-lg leading-relaxed text-[#1E3A8A]/78">
              <li>Tu sens qu'un oracle veut naître à travers toi.</li>
              <li>Tu veux créer depuis l'intuition plutôt que depuis une stratégie toute faite.</li>
              <li>Tu cherches un processus doux, intérieur et créatif.</li>
              <li>Tu acceptes que ton oracle puisse aussi venir te transformer.</li>
            </ul>
          </article>
          <article class="p-7 md:p-8 bg-[#F7F4EE] border border-[#1E3A8A]/10 rounded-sm">
            <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#D4845A] mb-5">Pas pour toi si...</p>
            <ul class="space-y-4 text-lg leading-relaxed text-[#1E3A8A]/78">
              <li>Tu veux une formation complète sur l'impression, l'édition ou le lancement.</li>
              <li>Tu veux une méthode très structurée, mentale et stratégique.</li>
              <li>Tu veux créer vite sans traverser le processus intérieur.</li>
              <li>Tu cherches une garantie de résultat commercial.</li>
            </ul>
          </article>
        </div>
      </section>

      <section id="prix" class="px-6 py-24">
        <div class="max-w-3xl mx-auto luxury-card bg-[#FFFCF6]/90 border border-[#1E3A8A]/10 rounded-sm p-8 md:p-12 text-center">
          <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#CC3DAA] mb-5">Mini-parcours complet</p>
          <h2 class="text-4xl md:text-5xl leading-tight font-normal mb-5">Rencontrer l'âme de ton oracle</h2>
          <p class="text-lg md:text-xl leading-relaxed text-[#1E3A8A]/75 mb-8">6 guidances audio, 6 fiches d'auto-coaching et l'ebook bonus pour poser les premières graines de ton oracle.</p>
          <div class="mb-8">
            <span class="text-6xl font-normal text-[#1E3A8A]">37</span>
            <span class="ui-text text-sm tracking-[0.18em] uppercase text-[#1E3A8A]/55"> CHF</span>
          </div>
          <a href="https://carolineverdier.kneo.me/form/181232d0c17b2dfe.html" class="inline-flex justify-center bg-[#CC3DAA] text-[#F7F4EE] ui-text text-xs tracking-[0.18em] uppercase px-9 py-4 rounded-sm hover:bg-[#D4845A] transition-colors">
            Commencer le rituel
          </a>
        </div>
      </section>

      <section class="px-6 pb-24">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-lg leading-relaxed italic text-[#1E3A8A]/65">
            Ces guidances sont issues d'un espace vivant de transmission. Elles ont été réorganisées ici comme un parcours autonome pour t'accompagner dans ton propre processus.
          </p>
        </div>
      </section>
    </main>

    <footer class="py-16 px-6 bg-[#1E3A8A] border-t border-white/5">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">
          <div class="flex items-center gap-4">
            <span class="text-[#CC3DAA] ui-text text-lg">*</span>
            <span class="text-white font-serif text-lg">L'Atelier <span class="font-light opacity-60">de Lucette</span></span>
          </div>
          <div class="flex items-center gap-8 text-xs uppercase tracking-widest text-white/70">
            <a href="#passages" class="hover:text-[#CC3DAA] transition-colors">Passages</a>
            <a href="#prix" class="hover:text-[#CC3DAA] transition-colors">Prix</a>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-xs text-white/65 font-light tracking-wide">
            &copy; 2026 L'Atelier de Lucette. Tous droits réservés.
            <span class="mx-2 opacity-40">|</span>
            <a href="/mentions-legales" class="hover:text-[#CC3DAA] transition-colors">Mentions légales</a>
            <span class="mx-2 opacity-40">|</span>
            <a href="/cgv" class="hover:text-[#CC3DAA] transition-colors">CGV</a>
          </p>
          <p class="text-[0.6rem] text-white/55 uppercase tracking-widest font-light">
            Discernement · Intuition · Action
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
