---
import '../../styles/global.css';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ton espace audio — Mini-rituel — L'Atelier de Lucette</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --cream: #F7F4EE;
        --bone: #FFFCF6;
        --gold: #C9A96E;
        --gold-light: #F1D9A7;
        --terracotta: #D4845A;
        --blue: #1E3A8A;
        --blue-dark: #1f2b58;
        --cyan: #2AACCB;
        --magenta: #CC3DAA;
        --white: #FFFFFF;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Cormorant Garamond', Georgia, serif;
        background: var(--cream);
        color: var(--blue);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .script { font-family: 'Cormorant Garamond', Georgia, serif; }
      .stamp { font-family: 'Special Elite', 'Courier New', monospace; }
      .bg-grain {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
      }

      audio {
        width: 100%;
        height: 44px;
        border-radius: 4px;
      }
      audio::-webkit-media-controls-panel {
        background: var(--bone);
      }

      .resource-card {
        background: var(--white);
        border: 1px solid rgba(30,58,138,0.08);
        border-radius: 4px;
        transition: box-shadow 0.3s ease;
      }
      .resource-card:hover {
        box-shadow: 0 12px 32px -8px rgba(30,58,138,0.08);
      }

      .download-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        background: var(--blue);
        color: var(--cream);
        font-family: 'Special Elite', 'Courier New', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 3px;
        transition: background 0.3s ease, transform 0.2s ease;
        cursor: pointer;
        border: none;
      }
      .download-btn:hover {
        background: var(--magenta);
        transform: translateY(-1px);
      }
      .download-btn:active {
        transform: translateY(0);
      }
    </style>
  </head>

  <body class="selection:bg-[#CC3DAA] selection:text-[#F7F4EE]">
    <div class="bg-grain fixed inset-0 pointer-events-none z-0"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 inset-x-0 z-30 h-20 flex items-center border-b border-[#1E3A8A]/15 bg-[#F7F4EE]/90 backdrop-blur-md">
      <div class="max-w-4xl mx-auto w-full px-6 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <span class="text-xl font-serif font-normal tracking-tight text-[#1E3A8A]">L'Atelier <span class="font-light opacity-70">de Lucette</span></span>
        </a>
        <a href="/mini-rituel" class="stamp text-[0.6rem] tracking-[0.25em] uppercase text-[#1E3A8A]/70 hover:text-[#CC3DAA] transition-colors">
          Mini-rituel
        </a>
      </div>
    </nav>

    <!-- Main -->
    <main class="relative z-10 pt-28 pb-24 px-6 min-h-screen flex flex-col items-center">
      <div class="max-w-2xl mx-auto w-full">
        <!-- Header -->
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-4 mb-6">
            <div class="h-px w-8 bg-[#2AACCB]"></div>
            <span class="stamp text-[0.55rem] tracking-[0.25em] uppercase text-[#1E3A8A]/70">Ton espace audio</span>
            <div class="h-px w-8 bg-[#CC3DAA]"></div>
          </div>
          <h1 class="script text-4xl md:text-5xl text-[#1E3A8A] leading-[1.1] mb-4 font-normal">
            Bienvenue dans ton<br />mini-rituel
          </h1>
          <p class="text-lg md:text-xl text-[#1E3A8A]/75 font-light italic leading-relaxed">
            Tout ce dont tu as besoin est ici. Installe-toi, prends 15 minutes pour toi.
          </p>
        </div>

        <!-- Audio 1 : Guide des 3 voix -->
        <div class="resource-card p-6 md:p-8 mb-6">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-10 h-10 rounded-full bg-[#F7F4EE] flex items-center justify-center shrink-0 text-[#CC3DAA]">
              <iconify-icon icon="solar:stars-minimalistic-linear" width="20" height="20" stroke-width="1.5"></iconify-icon>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between gap-4 mb-1">
                <h2 class="script text-xl md:text-2xl text-[#1E3A8A] font-medium">Le guide des 3 voix</h2>
                <span class="stamp text-[0.55rem] tracking-[0.2em] uppercase text-[#1E3A8A]/50 whitespace-nowrap">Bonus</span>
              </div>
              <p class="text-sm text-[#1E3A8A]/65 font-light leading-relaxed mb-4">
                Pourquoi est-ce si dur d'écouter son intuition ? Parce qu'en vrai tu entends trois voix en même temps. Ce guide t'aide à les distinguer.
              </p>
            </div>
          </div>
          <audio controls preload="none">
            <source src="/audio/Audio%20les%203%20voix.mp3" type="audio/mpeg" />
          </audio>
          <div class="flex justify-end mt-3">
            <a href="/audio/Audio%20les%203%20voix.mp3" download class="download-btn text-[0.55rem]">
              <iconify-icon icon="solar:download-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
              Télécharger l'audio
            </a>
          </div>
        </div>

        <!-- Audio 2 : Mini-rituel guidé -->
        <div class="resource-card p-6 md:p-8 mb-6">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-10 h-10 rounded-full bg-[#F7F4EE] flex items-center justify-center shrink-0 text-[#CC3DAA]">
              <iconify-icon icon="solar:music-note-slider-linear" width="20" height="20" stroke-width="1.5"></iconify-icon>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between gap-4 mb-1">
                <h2 class="script text-xl md:text-2xl text-[#1E3A8A] font-medium">L'audio guidé du mini-rituel</h2>
                <span class="stamp text-[0.55rem] tracking-[0.2em] uppercase text-[#1E3A8A]/50 whitespace-nowrap">15:00</span>
              </div>
              <p class="text-sm text-[#1E3A8A]/65 font-light leading-relaxed mb-4">
                Pose ta question, ferme les yeux, laisse-toi guider. Un rituel en 5 étapes pour passer du brouillard à l'action juste.
              </p>
            </div>
          </div>
          <audio controls preload="none">
            <source src="/audio/Audio%20Mini%20Rituel%20v2.mp3" type="audio/mpeg" />
          </audio>
          <div class="flex justify-end mt-3">
            <a href="/audio/Audio%20Mini%20Rituel%20v2.mp3" download class="download-btn text-[0.55rem]">
              <iconify-icon icon="solar:download-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
              Télécharger l'audio
            </a>
          </div>
        </div>

        <!-- PDF -->
        <div class="resource-card p-6 md:p-8 bg-[#1E3A8A] border-[#1E3A8A] relative overflow-hidden">
          <div class="bg-grain absolute inset-0 opacity-10"></div>
          <div class="relative z-10">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 text-[#CC3DAA] border border-white/10">
                <iconify-icon icon="solar:file-text-linear" width="20" height="20" stroke-width="1.5"></iconify-icon>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center justify-between gap-4 mb-1">
                  <h2 class="script text-xl md:text-2xl text-white font-medium">La fiche PDF d'exercice</h2>
                  <span class="stamp text-[0.55rem] tracking-[0.2em] uppercase text-[#CC3DAA] whitespace-nowrap">Bonus</span>
                </div>
                <p class="text-sm text-[#C9A96E] font-light leading-relaxed mb-2">
                  Imprime-la ou ouvre-la à côté de toi pendant l'audio. Chaque étape a son espace d'écriture.
                </p>
                <p class="text-xs text-[#C9A96E]/70 font-light italic">
                  Mini-rituel — Viens avec une question, repars avec une action
                </p>
              </div>
            </div>
            <div class="flex justify-end mt-2">
              <a href="/pdf/Mini-rituel%20%E2%80%94%20Viens%20avec%20une%20question%2C%20repars%20avec%20une%20action.pdf" download class="download-btn bg-[#CC3DAA] text-white hover:bg-[#D4845A] text-[0.55rem]">
                <iconify-icon icon="solar:download-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
                Télécharger le PDF
              </a>
            </div>
          </div>
        </div>

        <!-- Footer note -->
        <div class="text-center mt-12">
          <p class="text-sm text-[#1E3A8A]/40 font-light italic">
            Un doute, une question ? Réponds simplement à l'email que tu as reçu.
          </p>
        </div>
      </div>
    </main>
  </body>
</html>
