---
import '../styles/global.css';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CGV — L'Atelier de Lucette</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNKPGHZL0Y"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (window.location.search.includes('tr=internal')) {
        try { localStorage.setItem('__internal', '1'); } catch(e) {}
      }
      var __int = false;
      try { __int = localStorage.getItem('__internal') === '1'; } catch(e) {}
      gtag('config', 'G-SNKPGHZL0Y', __int ? { 'traffic_type': 'internal' } : {});
    </script>
    <style>
      :root {
        --color-cream: #F5F0E8;
        --color-bone: #FFFCF6;
        --color-sable: #CDAE72;
        --color-sable-doux: #F1D9A7;
        --color-terre: #D58458;
        --color-terre-fonce: #263F93;
        --color-eau: #31B6CC;
        --color-eau-fonce: #263F93;
        --color-magenta: #C83AB7;
        --color-texte: #263F93;
        --color-texte-doux: #1f2b58;
        --color-blanc: #FFFFFF;
      }
      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background-color: var(--color-cream);
        color: var(--color-texte);
        -webkit-font-smoothing: antialiased;
      }
      button, a, .ui-text, [class*="uppercase"] {
        font-family: 'Special Elite', 'Courier New', monospace;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Cormorant Garamond', serif;
      }
      h1 .italic, h2 .italic {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
      }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-thumb { background: var(--color-sable-doux); border-radius: 0; }
    </style>
  </head>

  <body class="selection:bg-[#C83AB7] selection:text-[#F5F0E8] text-lg">
    <!-- Navigation -->
    <nav class="fixed top-0 inset-x-0 z-50 h-24 flex items-center border-b border-[#263F93]/20 bg-[#F5F0E8]/90 backdrop-blur-md">
      <div class="max-w-7xl mx-auto w-full px-8 flex items-center justify-between">
        <a href="/" class="flex items-center gap-4 group">
          <div class="text-[#263F93] group-hover:text-[#C83AB7] transition-colors duration-500">
            <iconify-icon icon="solar:stars-minimalistic-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
          </div>
          <span class="text-xl font-serif font-normal tracking-tight text-[#263F93]">L'Atelier <span class="font-light opacity-70">de Lucette</span></span>
        </a>

        <div class="flex items-center">
          <a href="/#pricing" class="bg-[#C83AB7] text-[#F5F0E8] text-xs font-medium tracking-widest uppercase px-8 py-4 hover:bg-[#D58458] transition-all duration-500 rounded-sm">
            Recevoir
          </a>
        </div>
      </div>
    </nav>

    <!-- Content -->
    <main class="pt-40 pb-32 px-6 max-w-4xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex items-center gap-4 mb-8">
          <div class="h-[1px] w-12 bg-[#C83AB7]"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-[#C83AB7]">Conditions</span>
        </div>
        <h1 class="text-5xl md:text-6xl font-serif text-[#263F93] tracking-tight leading-[1.1]">
          Conditions g&eacute;n&eacute;rales de vente
        </h1>
        <p class="text-lg text-[#263F93]/70 mt-6 font-light">Derni&egrave;re mise &agrave; jour : juin 2026</p>
      </div>

      <div class="space-y-12 text-[#263F93]/85 leading-relaxed font-light">
        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">1. Prestations concern&eacute;es</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>Les pr&eacute;sentes CGV r&eacute;gissent les prestations suivantes propos&eacute;es par L'Atelier de Lucette :</p>
            <ul class="mt-4 space-y-3 list-disc pl-6">
              <li>Vente de produits physiques : oracle <em>D'une Rive &agrave; l'Autre</em></li>
              <li>Prestations de services : accompagnements individuels, constellations, ateliers</li>
              <li>Produits num&eacute;riques : mini-rituel guid&eacute;, fiches PDF, guides</li>
            </ul>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">2. Vente de produits physiques (oracle)</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm space-y-4">
            <h3 class="text-xl font-serif text-[#263F93]">2.1 Prix</h3>
            <p>Les prix sont indiqu&eacute;s en francs suisses (CHF), toutes taxes comprises. Conform&eacute;ment &agrave; l'art. 10 LTVA, Caroline Verdier n'est pas assujettie &agrave; la TVA.</p>

            <h3 class="text-xl font-serif text-[#263F93]">2.2 Commande</h3>
            <p>La commande est confirm&eacute;e apr&egrave;s validation du panier et paiement int&eacute;gral. Un email de confirmation est envoy&eacute; &agrave; l'adresse renseign&eacute;e.</p>

            <h3 class="text-xl font-serif text-[#263F93]">2.3 Paiement</h3>
            <p>Le paiement s'effectue par carte bancaire ou moyen de paiement propos&eacute; lors de la commande. Le d&eacute;bit est effectu&eacute; au moment de la confirmation.</p>

            <h3 class="text-xl font-serif text-[#263F93]">2.4 Livraison</h3>
            <p>La livraison est effectu&eacute;e &agrave; l'adresse indiqu&eacute;e par le client. Les d&eacute;lais de livraison varient selon la destination et le transporteur. Caroline Verdier ne peut &ecirc;tre tenue responsable des retards imputables au transporteur.</p>

            <h3 class="text-xl font-serif text-[#263F93]">2.5 R&eacute;tractation et retour</h3>
            <p>Conform&eacute;ment &agrave; la loi, le client dispose d'un d&eacute;lai de 14 jours &agrave; compter de la r&eacute;ception pour exercer son droit de r&eacute;tractation, sans motif. Les frais de retour sont &agrave; la charge du client. Le produit doit &ecirc;tre retourn&eacute; dans son &eacute;tat d'origine, dans son emballage d'origine. Le remboursement est effectu&eacute; dans un d&eacute;lai de 14 jours apr&egrave;s r&eacute;ception du produit retourn&eacute;.</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">3. Prestations de services</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm space-y-4">
            <h3 class="text-xl font-serif text-[#263F93]">3.1 Prise de rendez-vous</h3>
            <p>La r&eacute;servation est confirm&eacute;e apr&egrave;s accord mutuel sur la date et le r&egrave;glement de l'acompte ou de la totalit&eacute; de la prestation, selon les modalit&eacute;s communiqu&eacute;es lors de la r&eacute;servation.</p>

            <h3 class="text-xl font-serif text-[#263F93]">3.2 Annulation et report</h3>
            <p>Toute annulation doit &ecirc;tre communiqu&eacute;e par email &agrave; <a href="mailto:hello@carolineverdier.com" class="text-[#C83AB7] hover:underline">hello@carolineverdier.com</a> au moins 48 heures avant le rendez-vous. Pass&eacute; ce d&eacute;lai, le montant total de la prestation reste acquis.</p>

            <h3 class="text-xl font-serif text-[#263F93]">3.3 D&eacute;roulement</h3>
            <p>Les prestations se d&eacute;roulent en pr&eacute;sentiel (Genève) ou en visioconf&eacute;rence selon le type d'accompagnement. Le client s'engage &agrave; &ecirc;tre ponctuel et dans des conditions propices &agrave; l'&eacute;change.</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">4. Produits num&eacute;riques</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>Les produits num&eacute;riques (vid&eacute;os, PDF, guides) sont fournis par t&eacute;l&eacute;chargement ou par email apr&egrave;s inscription. Compte tenu de leur nature d&eacute;mat&eacute;rialis&eacute;e, ces produits ne sont pas sujets &agrave; retour. En cas de difficult&eacute; d'acc&egrave;s, contactez <a href="mailto:hello@carolineverdier.com" class="text-[#C83AB7] hover:underline">hello@carolineverdier.com</a>.</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">5. Propri&eacute;t&eacute; intellectuelle</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>Tous les contenus (textes, illustrations, cartes oracle, vid&eacute;os, design) sont la propri&eacute;t&eacute; exclusive de Caroline Verdier et sont prot&eacute;g&eacute;s par le droit d'auteur. Toute reproduction, distribution ou modification sans autorisation &eacute;crite est interdite.</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">6. Responsabilit&eacute;</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>Les prestations propos&eacute;es par L'Atelier de Lucette sont des accompagnements &agrave; vis&eacute;e de d&eacute;veloppement personnel et de discernement. Elles ne se substituent en aucun cas &agrave; un suivi m&eacute;dical, psychologique ou psychiatrique. Le client reconna&icirc;t utiliser ces services en toute responsabilit&eacute;.</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">7. Litiges et droit applicable</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>Les pr&eacute;sentes CGV sont soumises au droit suisse. En cas de litige, les parties s'efforceront de trouver une solution amiable avant toute proc&eacute;dure. Le for juridique est Genève, Suisse.</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-serif text-[#263F93] mb-4 tracking-tight">8. Contact</h2>
          <div class="bg-white border border-[#263F93]/12 p-8 rounded-sm">
            <p>Pour toute question relative aux pr&eacute;sentes CGV, vous pouvez contacter Caroline Verdier &agrave; <a href="mailto:hello@carolineverdier.com" class="text-[#C83AB7] hover:underline">hello@carolineverdier.com</a>.</p>
          </div>
        </section>
      </div>
    </main>

    <!-- Footer -->
    <footer class="py-16 px-6 bg-[#263F93] border-t border-white/5">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">
          <a href="/" class="flex items-center gap-4 group">
            <iconify-icon icon="solar:stars-minimalistic-linear" class="text-[#C83AB7] group-hover:text-[#D58458] transition-colors" width="20" height="20" stroke-width="1.5"></iconify-icon>
            <span class="text-white font-serif text-lg">L'Atelier <span class="font-light opacity-60">de Lucette</span></span>
          </a>

          <div class="flex items-center gap-12 text-xs uppercase tracking-widest text-white/70">
            <a href="/" class="hover:text-[#C83AB7] transition-colors">M&eacute;thode</a>
            <a href="/#rituel" class="hover:text-[#C83AB7] transition-colors">Rituel</a>
            <a href="/#histoire" class="hover:text-[#C83AB7] transition-colors">Histoire</a>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-xs text-white/65 font-light tracking-wide">
            &copy; 2026 L'Atelier de Lucette. Tous droits r&eacute;serv&eacute;s.
            <span class="mx-2 opacity-40">|</span>
            <a href="/mentions-legales" class="hover:text-[#C83AB7] transition-colors">Mentions l&eacute;gales</a>
            <span class="mx-2 opacity-40">|</span>
            <a href="/cgv" class="hover:text-[#C83AB7] transition-colors">CGV</a>
          </p>
          <p class="text-[0.6rem] text-white/55 uppercase tracking-widest font-light">
            Discernement &mdash; Intuition &mdash; Action
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
