---
import '../styles/global.css';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rencontre l'énergie de ton oracle — L'Atelier de Lucette</title>
    <meta
      name="description"
      content="Une première guidance offerte pour écouter l'oracle qui veut naître à travers toi, avant de chercher à le construire avec le mental."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNKPGHZL0Y"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (window.location.search.includes('tr=internal')) {
        try { localStorage.setItem('__internal', '1'); } catch(e) {}
      }
      var __int = false;
      try { __int = localStorage.getItem('__internal') === '1'; } catch(e) {}
      gtag('config', 'G-SNKPGHZL0Y', __int ? { 'traffic_type': 'internal' } : {});
    </script>
    <script is:inline src="https://groot.mailerlite.com/js/w/webforms.min.js?v83147fa8ce2d95cb73ece7f28b469519" defer></script>
    <style>
      .ml-form-embedSubmitLoad { display: inline-block; width: 20px; height: 20px; }
      .ml-form-embedSubmitLoad:after { content: " "; display: block; width: 11px; height: 11px; margin: 4px auto; border-radius: 50%; border: 3px solid #fff; border-color: #fff #fff #fff transparent; animation: ml-spin 1.2s linear infinite; }
      @keyframes ml-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
      .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
      .ml-error input { border-color: #CC3DAA !important; }
    </style>
  </head>
  <body class="selection:bg-[#CC3DAA] selection:text-[#F7F4EE] overflow-x-hidden bg-[#F7F4EE] text-[#1E3A8A]">
    <div class="bg-grain fixed inset-0 pointer-events-none z-0"></div>
    <div class="arch-lines">
      <svg width="100%" height="100%" viewBox="0 0 1440 900" preserveAspectRatio="none">
        <line x1="12%" y1="0" x2="12%" y2="100%" stroke="#1E3A8A" stroke-width="0.5" />
        <line x1="88%" y1="0" x2="88%" y2="100%" stroke="#1E3A8A" stroke-width="0.5" />
        <line x1="0" y1="780" x2="1440" y2="360" stroke="#CC3DAA" stroke-width="0.5" opacity="0.55" />
      </svg>
    </div>

    <nav class="fixed top-0 inset-x-0 z-50 h-20 flex items-center border-b border-[#1E3A8A]/15 bg-[#F7F4EE]/90 backdrop-blur-md">
      <div class="max-w-6xl mx-auto w-full px-6 flex items-center justify-between">
        <a href="/" class="text-xl font-serif tracking-tight text-[#1E3A8A]">L'Atelier <span class="opacity-70">de Lucette</span></a>
        <a href="#recevoir" class="ui-text text-xs tracking-[0.22em] uppercase text-[#1E3A8A]/75 hover:text-[#CC3DAA] transition-colors">Recevoir</a>
      </div>
    </nav>

    <main class="relative z-10">
      <header class="min-h-screen flex items-center px-6 pt-28 pb-20">
        <div class="max-w-5xl mx-auto grid md:grid-cols-[1.1fr_0.9fr] gap-12 items-center">
          <section>
            <div class="inline-flex items-center gap-4 mb-8">
              <div class="h-px w-10 bg-[#2AACCB]"></div>
              <span class="ui-text text-xs tracking-[0.22em] uppercase text-[#1E3A8A]/70">Guidance offerte</span>
              <div class="h-px w-10 bg-[#CC3DAA]"></div>
            </div>
            <h1 class="text-5xl md:text-7xl leading-[1.02] font-normal tracking-tight mb-8">
              Rencontre l'énergie<br />de ton oracle
            </h1>
            <p class="text-xl md:text-2xl leading-relaxed italic text-[#1E3A8A]/80 mb-8 max-w-3xl">
              Une première guidance offerte pour écouter l'oracle qui veut naître à travers toi, avant de chercher à le construire avec le mental.
            </p>
            <p class="text-lg leading-relaxed text-[#1E3A8A]/75 max-w-2xl">
              En 12 minutes, tu es guidée pour sentir son énergie, percevoir son atmosphère, recevoir ses premiers messages et ouvrir un espace de création plus intuitif.
            </p>
          </section>

          <section id="recevoir" class="luxury-card bg-[#FFFCF6]/80 p-6 md:p-8 rounded-sm border border-[#1E3A8A]/10">
            <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#CC3DAA] mb-4">Recevoir la guidance</p>
            <h2 class="text-3xl md:text-4xl leading-tight font-normal mb-4">Ton oracle n'a pas besoin d'être inventé.</h2>
            <p class="text-lg leading-relaxed text-[#1E3A8A]/75 mb-6">Il peut d'abord être rencontré.</p>
            <div id="mlb2-42994970" class="ml-form-embedContainer ml-subscribe-form ml-subscribe-form-42994970">
              <div class="ml-form-align-center">
                <div class="ml-form-embedWrapper embedForm">
                  <div class="ml-form-embedBody row-form">
                    <form class="ml-block-form space-y-3" action="https://assets.mailerlite.com/jsonp/131564/forms/191155615916099278/subscribe" data-code="" method="post" target="_blank" aria-label="Formulaire guidance offerte">
                      <div class="ml-form-formContent space-y-3">
                        <div class="ml-form-fieldRow">
                          <div class="ml-field-group ml-field-name">
                            <input aria-label="name" type="text" class="form-control w-full px-4 py-3 border border-[#1E3A8A]/20 rounded-sm bg-[#F7F4EE] text-[#1E3A8A] placeholder-[#1E3A8A]/45 focus:outline-none focus:border-[#CC3DAA]" name="fields[name]" placeholder="Prénom" autocomplete="given-name" />
                          </div>
                        </div>
                        <div class="ml-form-fieldRow ml-last-item">
                          <div class="ml-field-group ml-field-email ml-validate-email ml-validate-required">
                            <input aria-label="email" aria-required="true" type="email" class="form-control w-full px-4 py-3 border border-[#1E3A8A]/20 rounded-sm bg-[#F7F4EE] text-[#1E3A8A] placeholder-[#1E3A8A]/45 focus:outline-none focus:border-[#CC3DAA]" name="fields[email]" placeholder="Email" autocomplete="email" required />
                          </div>
                        </div>
                      </div>

                      <div class="ml-form-embedPermissions text-left">
                        <p class="text-xs leading-relaxed text-[#1E3A8A]/60 mb-3">
                          En t'inscrivant, tu recevras cette guidance offerte et quelques emails pour prolonger l'expérience. Tu peux te désinscrire à tout moment.
                        </p>
                      </div>

                      <input type="hidden" name="ml-submit" value="1" />
                      <div class="ml-form-embedSubmit">
                        <button type="submit" class="primary block w-full text-center bg-[#CC3DAA] text-[#F7F4EE] ui-text text-xs tracking-[0.2em] uppercase px-6 py-4 rounded-sm hover:bg-[#D4845A] transition-colors">
                          Recevoir la guidance offerte
                        </button>
                        <button disabled style="display: none;" type="button" class="loading w-full text-center bg-[#CC3DAA] text-[#F7F4EE] ui-text text-xs tracking-[0.2em] uppercase px-6 py-4 rounded-sm">
                          <div class="ml-form-embedSubmitLoad"></div>
                          <span class="sr-only">Chargement</span>
                        </button>
                      </div>
                      <input type="hidden" name="anticsrf" value="true" />
                    </form>
                  </div>

                  <div class="ml-form-successBody row-success" style="display: none;">
                    <div class="ml-form-successContent text-left">
                      <h4 class="text-2xl text-[#1E3A8A] mb-2 font-normal">C'est envoyé.</h4>
                      <p class="text-[#1E3A8A]/70">Va écouter la guidance et laisse venir ce qui veut naître.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <script is:inline>
              function ml_webform_success_42994970() {
                window.location.href = '/rencontrer-ton-oracle/acces';
              }
              fetch('https://assets.mailerlite.com/jsonp/131564/forms/191155615916099278/takel');
            </script>
          </section>
        </div>
      </header>

      <section class="px-6 py-24 bg-[#FFFCF6] border-y border-[#1E3A8A]/10">
        <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6">
          <article class="p-6 bg-[#F7F4EE] rounded-sm border border-[#1E3A8A]/10">
            <p class="ui-text text-xs tracking-[0.2em] uppercase text-[#2AACCB] mb-4">01</p>
            <h2 class="text-2xl font-normal mb-3">Si un oracle t'appelle</h2>
            <p class="leading-relaxed text-[#1E3A8A]/75">Cette guidance t'aide à écouter ce qui veut naître avant de le réduire à une idée, un plan ou une liste de cartes.</p>
          </article>
          <article class="p-6 bg-[#F7F4EE] rounded-sm border border-[#1E3A8A]/10">
            <p class="ui-text text-xs tracking-[0.2em] uppercase text-[#CC3DAA] mb-4">02</p>
            <h2 class="text-2xl font-normal mb-3">Ce que tu rencontres</h2>
            <p class="leading-relaxed text-[#1E3A8A]/75">Son atmosphère, son message, son mouvement, et les premières sensations qui peuvent devenir la matière de ton jeu.</p>
          </article>
          <article class="p-6 bg-[#F7F4EE] rounded-sm border border-[#1E3A8A]/10">
            <p class="ui-text text-xs tracking-[0.2em] uppercase text-[#D4845A] mb-4">03</p>
            <h2 class="text-2xl font-normal mb-3">Pas depuis le mental</h2>
            <p class="leading-relaxed text-[#1E3A8A]/75">Ce n'est pas une méthode technique. C'est une porte d'entrée intuitive pour sentir l'âme du jeu qui veut prendre forme.</p>
          </article>
        </div>
      </section>

      <section class="px-6 py-24">
        <div class="max-w-3xl mx-auto text-center">
          <p class="ui-text text-xs tracking-[0.22em] uppercase text-[#1E3A8A]/55 mb-6">Un mot de Caroline</p>
          <p class="text-3xl md:text-4xl leading-tight italic text-[#1E3A8A] mb-8">
            J'ai créé mon oracle en écoutant d'abord son énergie. Pas en forçant une structure parfaite.
          </p>
          <p class="text-lg leading-relaxed text-[#1E3A8A]/75">
            Cette première guidance ouvre le même espace : celui où l'oracle n'est pas un projet à contrôler, mais une présence à rencontrer, puis à mettre doucement en matière.
          </p>
          <a href="#recevoir" class="inline-flex mt-10 bg-[#1E3A8A] text-[#F7F4EE] ui-text text-xs tracking-[0.2em] uppercase px-8 py-4 rounded-sm hover:bg-[#CC3DAA] transition-colors">
            Recevoir la guidance offerte
          </a>
        </div>
      </section>
    </main>
  </body>
</html>
